  "triggers": [
    {
      "id": "scene_open_aigm",
      "when": {
        "event": "encounter_started"
      },
      "if": [],
      "then": [
        {
          "type": "send_aigm_message",
          "message": "SCENE — SOCIAL + EXPLORATION, no combat (don't start any). The intro is on screen: the ruined ward-complex, the thread of smoke from the half-roofed sanctum at the north end. Don't re-describe it. Eryn Cault sits by the fire in that sanctum but is HIDDEN at start — do NOT describe her, her location, or her appearance until Reed picks across the rubble into sight and the engine reveals her. She is a struck-off Cape, decades older than Reed — tired, guilty, not unkind. The CONVERSATION tree owns what she knows and releases it in layers (deeper truths behind Insight/Persuasion DC 12–14) — do NOT dump her lore in narration; let exploration and the conversation carry it. Reward careful listening and searching. The scene ends with her giving Reed the way down and a plain warning: no one will certify this for her."
        }
      ],
      "once": true
    },
    {
      "id": "eryn_hidden_until_seen",
      "when": {
        "event": "encounter_started"
      },
      "if": [],
      "then": [
        {
          "type": "set_npc_hidden",
          "defId": "eryn_cault",
          "hidden": true,
          "hideDC": 5,
          "revealedBy": "perception"
        }
      ],
      "once": true
    },
    {
      "id": "sanctum_smoke_log",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 0,
          "y": 0,
          "w": 8,
          "h": 6
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "show_log",
          "message": "A thin line of smoke curls from the sanctum's half-open roof — wood, not coal. Someone has been burning whatever the ruins give them, and doing it for a long time."
        }
      ],
      "once": true
    },
    {
      "id": "cache_healing_draught",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 13,
          "y": 5,
          "w": 5,
          "h": 5
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "perception",
          "dc": 10,
          "onPass": [
            {
              "type": "show_log",
              "message": "A flat stone has been wedged deliberately against the wall. Behind it, wrapped in oilcloth: a small vial of healing draught — old label, Arcanian dispensary stamp, still sealed."
            }
          ],
          "onFail": []
        }
      ],
      "once": true
    },
    {
      "id": "dedication_stone_arcana",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 0,
          "y": 4,
          "w": 8,
          "h": 5
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "perception",
          "dc": 12,
          "onPass": [
            {
              "type": "show_log",
              "message": "Half-buried in collapsed masonry near the sanctum threshold: a dedication stone, its face still legible. The inscription names the ward-binding rite — the Rite of Sealed Thresholds — and gives the first three lines of its opening formula. This is what a Cape must trace and seal at the keystone to renew the binding by hand. You copy it carefully. (The finale's difficulty is reduced.)"
            }
          ],
          "onFail": []
        }
      ],
      "once": true
    },
    {
      "id": "dedication_stone_xp",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 0,
          "y": 4,
          "w": 8,
          "h": 5
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "set_flag",
          "name": "dedication_stone_examined",
          "value": true
        }
      ],
      "once": true
    },
    {
      "id": "vael_seal_investigation",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 0,
          "y": 0,
          "w": 5,
          "h": 3
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "perception",
          "dc": 13,
          "onPass": [
            {
              "type": "show_log",
              "message": "Beneath a drift of ash near the fire-ring: a White Cape licence-seal, the kind worn at the throat ring. The engraving reads EDRAN VAEL, SR. CAPE, CIRCUIT DIVISION. It is not broken — he left it here deliberately, or set it down and did not come back for it."
            }
          ],
          "onFail": []
        }
      ],
      "once": true
    },
    {
      "id": "vael_seal_xp",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 0,
          "y": 0,
          "w": 5,
          "h": 3
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "set_flag",
          "name": "vael_seal_examined",
          "value": true
        }
      ],
      "once": true
    },
    {
      "id": "way_down_aigm",
      "when": {
        "event": "flag_set",
        "name": "sage_way_down_given"
      },
      "if": [],
      "then": [
        {
          "type": "send_aigm_message",
          "message": "Cault has given Reed the way down — a trapdoor at the sanctum's rear, kept clear out of habit. She won't watch her go. Close on one quiet beat: the canvas falling back, the iron pull cold under Reed's hand, the fire still burning. No new dialogue from Cault — the conversation has said its piece."
        }
      ],
      "once": true
    }
  ]
}