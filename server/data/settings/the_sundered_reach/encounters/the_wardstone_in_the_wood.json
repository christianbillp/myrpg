  "placementMode": "exact",
  "placements": [
    {
      "role": "player",
      "x": 14,
      "y": 21
    },
    {
      "role": "neutral",
      "index": 0,
      "x": 18,
      "y": 9
    },
    {
      "role": "neutral",
      "index": 1,
      "x": 20,
      "y": 10
    }
  ],
  "triggers": [
    {
      "id": "read_aloud_start",
      "when": {
        "event": "encounter_started"
      },
      "if": [],
      "then": [
        {
          "type": "send_aigm_message",
          "message": "The intro is on screen — the old trail, the clearing, the cracked wardstone, the wrong cold. EXPLORATION PHASE: don't re-describe it; just open the moment and invite Reed to look around. No combat yet. The scavengers are hidden in the NE scrub — do NOT mention them or their positions until the combat trigger fires."
        }
      ],
      "once": true
    },
    {
      "id": "scavengers_hidden_at_start",
      "when": {
        "event": "encounter_started"
      },
      "if": [],
      "then": [
        {
          "type": "set_npc_hidden",
          "defId": "goblin_minion",
          "hidden": true,
          "revealedBy": "trigger"
        }
      ],
      "once": true
    },
    {
      "id": "wardstone_arcana",
      "when": {
        "event": "study_feature",
        "tile": {
          "x": 21,
          "y": 12
        }
      },
      "if": [],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "arcana",
          "dc": 12,
          "onPass": [
            {
              "type": "show_log",
              "message": "You press your fingers to the fault-line and read the glyph carefully. This is not a clean break — no tool did this. The ward decayed from within, the binding-matrix unravelling over years, maybe decades. Whatever the Old Empire set here to keep the moor quiet, it simply… stopped. The crack is a symptom, not a wound. Whoever is responsible, it isn't sabotage."
            }
          ],
          "onFail": [
            {
              "type": "show_log",
              "message": "The glyph's logic slips away from you — too worn, or too far beyond your training to read on the first pass. You could study it again."
            }
          ]
        }
      ],
      "once": false
    },
    {
      "id": "wardstone_tracks",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 17,
          "y": 12,
          "w": 3,
          "h": 2
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "perception",
          "dc": 10,
          "onPass": [
            {
              "type": "show_log",
              "message": "You crouch over the scuffed litter near the stone. Small clawed prints, three-toed, pressed deep as if carrying weight. Recent: the mud hasn't dried. Two sets, both leading the same direction: into the scrub to the north-east. Whatever made these came here more than once."
            }
          ],
          "onFail": []
        }
      ],
      "once": true
    },
    {
      "id": "wardstone_vial",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 22,
          "y": 12,
          "w": 2,
          "h": 2
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "player_ability_check",
          "skill": "perception",
          "dc": 12,
          "onPass": [
            {
              "type": "show_log",
              "message": "Wedged into a gap at the stone's base, wrapped tight in oilcloth and sealed with a Cape's wax stamp: a small glass vial, a dull red liquid inside. A healing draught, cached here by someone who meant to come back. The stamp is old — a licensing mark from three seasons ago. They didn't come back."
            }
          ],
          "onFail": []
        }
      ],
      "once": true
    },
    {
      "id": "nest_disturbed",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 20,
          "y": 11,
          "w": 3,
          "h": 3
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "show_announcement",
          "text": "The undergrowth erupts — the scavengers break from cover!",
          "durationMs": 2500,
          "mode": "unfocused"
        },
        {
          "type": "set_npc_hidden",
          "defId": "goblin_minion",
          "hidden": false
        },
        {
          "type": "set_disposition_by_def_id",
          "defId": "goblin_minion",
          "disposition": "enemy"
        },
        {
          "type": "trigger_combat"
        },
        {
          "type": "npc_speaks",
          "entity": "enemy_A",
          "text": "A Cape! Pockets full o' shinies — stick it, stick it!"
        }
      ],
      "once": true
    },
    {
      "id": "nest_aigm_cue",
      "when": {
        "event": "player_moved",
        "in_area": {
          "x": 20,
          "y": 11,
          "w": 3,
          "h": 3
        }
      },
      "if": [
        {
          "type": "phase",
          "in": [
            "exploring"
          ]
        }
      ],
      "then": [
        {
          "type": "send_aigm_message",
          "message": "COMBAT BEGINS — two goblin scavengers break shrieking from the scrub, yelping for the shinies on the Cape's belt. Reed's first real fight: narrate the nerves, the hand finding the wand a beat before the mind catches up. Survivable but real; let small successes feel large, and make any spell land in the telling."
        }
      ],
      "once": true
    },
    {
      "id": "victory_aigm",
      "when": {
        "event": "encounter_completed"
      },
      "if": [],
      "then": [
        {
          "type": "send_aigm_message",
          "message": "ENCOUNTER COMPLETE — Reed's first fight is over. Quiet returns to the clearing; the cold still hangs around the cracked stone she can't mend here. This is only the first stone on the Circuit, and the line of them runs east — over the Blackgorge gorge to the old ward-complex at the Circuit's heart, where the next stone stands and where Vael's trail leads. Make that the reason she goes on, not just the road: she salvages what the scavengers carried and takes the dry road east. She has cast in anger now, and the door she knocked on did not answer. Let that change sit on her."
        }
      ],
      "once": true
    }
  ]
}